# Supabase auth (server-side via @supabase/ssr). Both vars are required for
# /login and the /editor gate to work. When unset, login degrades gracefully
# (the page renders a "not configured" notice and middleware skips the gate).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional observability
NEXT_PUBLIC_CLARITY_ID=
